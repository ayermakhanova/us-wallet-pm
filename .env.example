# Atlassian credentials for the daily Jira sync (scripts/sync-jira.ts).
# Generate an API token at https://id.atlassian.com/manage-profile/security/api-tokens
# In CI, these come from GitHub Actions secrets — see .github/workflows/sync.yml.

ATLASSIAN_EMAIL=your.email@riamoneytransfer.com
ATLASSIAN_API_TOKEN=replace-with-token-from-id.atlassian.com
JIRA_BASE_URL=https://euronet.atlassian.net
